{
  "name": "wanjuan-lingjing-storage-lab",
  "version": "1.2.8-storage-lab.2",
  "private": true,
  "description": "万卷灵境存储实验版 - 隔离验证媒体去重与诊断",
  "author": "",
  "main": "electron/main/index.cjs",
  "type": "module",
  "scripts": {
    "build:web": "vite build --config vite.config.mjs",
    "start": "electron .",
    "debug": "cross-env WANJUAN_DEBUG=1 electron .",
    "build": "vite build --config vite.config.mjs && electron-builder",
    "typecheck": "tsc --noEmit",
    "test:lib": "node scripts/test-lib.mjs",
    "test:storage": "node scripts/test-storage-lab.mjs",
    "test:storage:electron": "electron scripts/test-storage-electron.cjs",
    "test:storage:state": "node scripts/test-storage-state-policy.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "gsap": "^3.15.0",
    "localforage": "^1.10.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.4.2"
  },
  "build": {
    "appId": "com.wanjuan.lingjing.storage-lab",
    "productName": "万卷灵境-存储实验版",
    "artifactName": "万卷灵境-存储实验版-1.2.8-storage-lab.2-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "extendInfo": {
        "CFBundleShortVersionString": "1.2.8-storage-lab.2",
        "CFBundleVersion": "1.2.8.2"
      }
    }
  }
}
