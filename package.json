{
  "name": "wanjuan-lingjing",
  "version": "1.3.0",
  "private": true,
  "description": "万卷灵境 - macOS AI 创作画布桌面应用",
  "author": "",
  "main": "electron/main/index.cjs",
  "type": "module",
  "scripts": {
    "build:web": "vite build --config vite.config.mjs",
    "start": "electron .",
    "start:dev": "node scripts/start-dev.cjs",
    "debug": "cross-env WANJUAN_DEBUG=1 electron .",
    "build": "vite build --config vite.config.mjs && electron-builder",
    "build:win": "vite build --config vite.config.mjs && electron-builder --win --x64 --ia32",
    "build:win:x64": "vite build --config vite.config.mjs && electron-builder --win --x64",
    "build:win:x86": "vite build --config vite.config.mjs && electron-builder --win --ia32",
    "build:win:ia32": "vite build --config vite.config.mjs && electron-builder --win --ia32",
    "typecheck": "tsc --noEmit",
    "test:lib": "node scripts/test-lib.mjs",
    "test:windows-paths": "node scripts/test-windows-file-url-paths.cjs",
    "test:extension-tools": "node scripts/test-extension-tool-runtime.cjs",
    "test:update-checker": "electron scripts/test-update-checker.cjs",
    "test:storage": "node scripts/test-storage-lab.mjs",
    "test:storage:electron": "electron scripts/test-storage-electron.cjs",
    "test:storage:state": "node scripts/test-storage-state-policy.mjs",
    "scan:storage-preview": "node scripts/scan-storage-migration-preview.mjs",
    "test:migrate-project": "node scripts/migrate-project-media-test.mjs",
    "test:migrated-project:electron": "electron scripts/test-migrated-project-electron.cjs",
    "test:storage:real-project": "electron scripts/test-real-project-transaction.cjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "gsap": "^3.15.0",
    "localforage": "^1.10.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.wanjuan.lingjing",
    "productName": "万卷灵境",
    "artifactName": "万卷灵境-1.3.0-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "tool-runtime",
        "to": "tool-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "extendInfo": {
        "CFBundleShortVersionString": "1.3.0",
        "CFBundleVersion": "1.3.0"
      }
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "万卷灵境"
    }
  }
}
